# Copy this file to .env on the deployment host and replace every secret value.

SPRING_DATASOURCE_URL=jdbc:mysql://db.example.internal:3306/compensation?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=true&allowPublicKeyRetrieval=false
SPRING_DATASOURCE_USERNAME=compensation_app
SPRING_DATASOURCE_PASSWORD=replace-with-a-database-password

REDIS_PASSWORD=replace-with-a-redis-password
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
EXTERNAL_API_JWT_SECRET=replace-with-a-separate-random-secret-at-least-32-characters
ENCRYPTION_SM4_KEY=replace-with-a-random-sm4-key
ENCRYPTION_AES_KEY=replace-with-a-random-aes-key

OAUTH_TRUSTED_REDIRECT_HOSTS=comp.yiykj.com
APP_IMAGE=compensation-backend:production
WEB_IMAGE=compensation-web:production
VITE_API_BASE_URL=/api
VITE_APP_NAME=Compensation%20Admin
VITE_OAUTH_REDIRECT_URI_WECHAT=https://comp.yiykj.com/oauth/callback/wechat

# Keep the default false unless a RabbitMQ service and credentials are configured.
SPRING_RABBITMQ_LISTENER_SIMPLE_AUTO_STARTUP=false

# Run idempotent startup migrations after taking a database backup.
MIGRATION_RUNNER_ENABLED=true

# Bind the web container publicly only when TLS is terminated elsewhere.
WEB_BIND_ADDRESS=0.0.0.0
WEB_PORT=80

# Optional: use an internal or regional registry mirror for the four base images.
# NODE_IMAGE=docker.m.daocloud.io/library/node:22-alpine
# MAVEN_IMAGE=docker.m.daocloud.io/library/maven:3.9-eclipse-temurin-17
# JRE_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:17-jre-jammy
# NGINX_IMAGE=docker.m.daocloud.io/library/nginx:1.27-alpine
# REDIS_IMAGE=docker.m.daocloud.io/library/redis:7.2-alpine
